{
  "name": "boilerplate",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --debug --watch",
    "start:prod": "NODE_ENV=production node dist/src/main",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "check-types": "tsc --noEmit",
    "db:generate": "prisma generate --schema=src/core/infra/db/structure/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=src/core/infra/db/structure/schema.prisma",
    "db:studio": "prisma studio --schema=src/core/infra/db/structure/schema.prisma",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --maxWorkers=4 --coverageReporters=lcov",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "version": "echo $npm_package_version",
    "prepare": "if [ -f node_modules/.bin/husky ]; then husky; fi"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "11.1.11",
    "@nestjs/swagger": "11.4.2",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/websockets": "11.1.11",
    "@prisma/client": "^6.17.0",
    "@sentry/node": "^10.20.0",
    "axios": "1.15.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "helmet": "8.1.0",
    "ioredis": "5.8.2",
    "nestjs-cls": "6.2.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "4.8.3",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "11.1.19",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "29.5.14",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "29.7.0",
    "jest-junit": "8.0.0",
    "lint-staged": "^16.2.3",
    "prettier": "^3.4.2",
    "prisma": "^6.17.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "29.4.9",
    "ts-loader": "9.5.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "jest --no-cache --passWithNoTests"
    ]
  }
}